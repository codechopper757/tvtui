#!/usr/bin/env python3
import curses
import json
import subprocess
import urllib.request
import datetime
import time
from zoneinfo import ZoneInfo
from dotenv import load_dotenv
import os
from pathlib import Path

BASE_DIR = Path(__file__).resolve().parent
load_dotenv(BASE_DIR / ".env")

LOCAL_TZ  = ZoneInfo(os.getenv("LOCAL_TZ", "America/New_York"))
HDHR_IP   = os.getenv("HDHR_IP")
JURL      = os.getenv("JELLYFIN_URL", "").rstrip("/")
JKEY      = os.getenv("JELLYFIN_API_KEY")


# ---------------------------------------------------------------------------
# Jellyfin API
# ---------------------------------------------------------------------------

def jget(path):
    """HTTP/HTTPS-agnostic Jellyfin GET, returns parsed JSON."""
    url = f"{JURL}{path}"
    if url.startswith("https"):
        import ssl
        ctx = ssl._create_unverified_context()
        with urllib.request.urlopen(url, context=ctx, timeout=6) as r:
            return json.load(r)
    with urllib.request.urlopen(url, timeout=6) as r:
        return json.load(r)


def fetch_jellyfin_channels():
    """
    Single endpoint call that returns channel list with CurrentProgram embedded.
    Always uses fresh IDs so Jellyfin restarts don't break the mapping.
    """
    try:
        data = jget(
            f"/LiveTv/Channels"
            f"?EnableUserData=true&AddCurrentProgram=true"
            f"&api_key={JKEY}"
        )
        return data.get("Items", [])
    except Exception:
        return []


def fetch_channel_epg(channel_id):
    """
    Fetch upcoming and previous programs for a single channel.
    Uses HasAired filter instead of date range to avoid stale EPG cache issues.
    Returns a combined list: [previous..., current, upcoming...]
    """
    try:
        upcoming = jget(
            f"/LiveTv/Programs?ChannelIds={channel_id}"
            f"&HasAired=false&Limit=5"
            f"&SortBy=StartDate&SortOrder=Ascending"
            f"&api_key={JKEY}"
        ).get("Items", [])
    except Exception:
        upcoming = []

    try:
        previous = jget(
            f"/LiveTv/Programs?ChannelIds={channel_id}"
            f"&HasAired=true&Limit=2"
            f"&SortBy=StartDate&SortOrder=Descending"
            f"&api_key={JKEY}"
        ).get("Items", [])
    except Exception:
        previous = []

    return previous + upcoming


# ---------------------------------------------------------------------------
# HDHomeRun
# ---------------------------------------------------------------------------

def fetch_hdhr_channels():
    url = f"http://{HDHR_IP}/lineup.json"
    with urllib.request.urlopen(url, timeout=3) as r:
        return json.load(r)


def launch_mpv(channel_number):
    url = f"http://{HDHR_IP}:5004/auto/v{channel_number}"
    try:
        subprocess.run(["pkill", "-9", "mpv"], stderr=subprocess.DEVNULL)
        time.sleep(0.2)
    except Exception:
        pass
    curses.def_prog_mode()
    curses.endwin()
    subprocess.Popen([
        "mpv", "--cache=yes", "--cache-secs=30",
        "--no-terminal", "--msg-level=all=no",
        "--autofit=75%x75%", "--save-position-on-quit", url,
    ])
    curses.reset_prog_mode()
    curses.curs_set(0)


# ---------------------------------------------------------------------------
# EPG helpers
# ---------------------------------------------------------------------------

def parse_utc(s):
    return datetime.datetime.fromisoformat(s.replace("Z", "+00:00")).replace(tzinfo=None)


def to_local(dt_naive_utc):
    return dt_naive_utc.replace(tzinfo=datetime.timezone.utc).astimezone(LOCAL_TZ)


def get_current_program(programs, now_utc):
    for p in programs:
        try:
            if parse_utc(p["StartDate"]) <= now_utc < parse_utc(p["EndDate"]):
                return p
        except Exception:
            continue
    return None


def get_upcoming_programs(programs, after_utc, count=3):
    try:
        upcoming = sorted(
            [(parse_utc(p["StartDate"]), p) for p in programs
             if parse_utc(p.get("StartDate", "1970-01-01Z")) >= after_utc],
            key=lambda x: x[0]
        )
        return [p for _, p in upcoming[:count]]
    except Exception:
        return []


def get_previous_program(programs, before_utc):
    try:
        prev = sorted(
            [(parse_utc(p["EndDate"]), p) for p in programs
             if parse_utc(p.get("EndDate", "1970-01-01Z")) <= before_utc],
            key=lambda x: x[0], reverse=True
        )
        return prev[0][1] if prev else None
    except Exception:
        return None


# ---------------------------------------------------------------------------
# UI helpers
# ---------------------------------------------------------------------------

def init_colors():
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1,  curses.COLOR_CYAN,    -1)
    curses.init_pair(2,  curses.COLOR_BLACK,   curses.COLOR_CYAN)
    curses.init_pair(4,  curses.COLOR_YELLOW,  -1)
    curses.init_pair(5,  curses.COLOR_MAGENTA, -1)
    curses.init_pair(6,  curses.COLOR_WHITE,   -1)
    curses.init_pair(7,  curses.COLOR_GREEN,   -1)
    curses.init_pair(8,  curses.COLOR_YELLOW,  -1)
    curses.init_pair(9,  curses.COLOR_RED,     -1)
    curses.init_pair(17, curses.COLOR_WHITE,   -1)
    curses.init_pair(18, curses.COLOR_GREEN,   -1)
    curses.init_pair(19, curses.COLOR_CYAN,    -1)


def draw_box(win, color):
    win.attron(curses.color_pair(color))
    win.box()
    win.attroff(curses.color_pair(color))


def draw_progress_bar(win, y, x, pct, width):
    filled = int(width * pct)
    color  = curses.color_pair(7 if pct < 0.5 else 8 if pct < 0.85 else 9)
    win.addstr(y, x, "[")
    win.attron(color)
    win.addstr(y, x + 1, "█" * filled)
    win.attroff(color)
    win.addstr(y, x + 1 + filled, "░" * (width - filled))
    win.addstr(y, x + width + 1, "]")


def fmt_countdown(sec):
    if sec < 0:
        return "00:00"
    h, r = divmod(int(sec), 3600)
    m, s = divmod(r, 60)
    return f"{h:02d}:{m:02d}:{s:02d}" if h else f"{m:02d}:{s:02d}"


def trunc(text, n):
    if not text:
        return ""
    return text if len(text) <= n else text[:n - 3] + "..."


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main(stdscr):
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.timeout(1000)
    init_colors()

    hdhr_channels     = fetch_hdhr_channels()

    jf_channels       = []
    jf_by_number      = {}
    last_jf_fetch     = 0

    selected_epg      = []
    last_epg_channel  = None
    last_epg_fetch    = 0

    selected          = 0
    scroll            = 0
    search_mode       = False
    search_query      = ""
    filtered_channels = hdhr_channels[:]

    while True:
        stdscr.clear()
        h, w = stdscr.getmaxyx()
        now  = datetime.datetime.utcnow()

        # Refresh Jellyfin channel list + CurrentProgram every 60s
        if time.time() - last_jf_fetch > 60:
            jf_channels   = fetch_jellyfin_channels()
            jf_by_number  = {c["Number"]: c for c in jf_channels if c.get("Number")}
            last_jf_fetch = time.time()

        display_channels = filtered_channels if (search_mode or search_query) else hdhr_channels
        if not display_channels:
            selected = 0
        else:
            selected = max(0, min(selected, len(display_channels) - 1))

        sel_ch   = display_channels[selected]
        sel_num  = sel_ch["GuideNumber"]
        jf_sel   = jf_by_number.get(sel_num, {})
        jf_sel_id = jf_sel.get("Id")

        # Refresh per-channel EPG when selection changes or every 5 min
        if jf_sel_id and (
            jf_sel_id != last_epg_channel
            or time.time() - last_epg_fetch > 300
        ):
            selected_epg     = fetch_channel_epg(jf_sel_id)
            last_epg_channel = jf_sel_id
            last_epg_fetch   = time.time()

        # Header
        header = " HDHomeRun Live TV Dashboard "
        stdscr.attron(curses.color_pair(1) | curses.A_BOLD)
        stdscr.addnstr(0, (w - len(header)) // 2, header, w - 2)
        stdscr.attroff(curses.color_pair(1) | curses.A_BOLD)

        pane_width = w // 2
        left  = stdscr.derwin(h - 2, pane_width,     1, 0)
        right = stdscr.derwin(h - 2, w - pane_width, 1, pane_width)
        draw_box(left,  5)
        draw_box(right, 5)

        left.attron(curses.color_pair(1))
        left.addnstr(0, 2, " Channels ", pane_width - 4)
        left.attroff(curses.color_pair(1))

        view_height = h - 6
        if selected < scroll:
            scroll = selected
        elif selected >= scroll + view_height:
            scroll = selected - view_height + 1

        max_name_len = 20
        max_prog_len = pane_width - max_name_len - 15

        for idx in range(scroll, min(scroll + view_height, len(display_channels))):
            y   = idx - scroll + 1
            ch  = display_channels[idx]
            jf  = jf_by_number.get(ch["GuideNumber"], {})
            cp  = (jf.get("CurrentProgram") or {})
            prog_preview = trunc(cp.get("Name", ""), max_prog_len)
            ch_num  = f"{ch['GuideNumber']:>6}"
            ch_name = trunc(ch["GuideName"], max_name_len)

            if idx == selected:
                left.attron(curses.color_pair(2))
                line = (f"{ch_num}  {ch_name:<{max_name_len}} │ {prog_preview}"
                        if prog_preview else f"{ch_num}  {ch_name}")
                left.addnstr(y, 2, line.ljust(pane_width - 4), pane_width - 4)
                left.attroff(curses.color_pair(2))
            else:
                x = 2
                left.attron(curses.color_pair(1))
                left.addnstr(y, x, ch_num, len(ch_num))
                left.attroff(curses.color_pair(1))
                x += len(ch_num) + 2
                left.attron(curses.color_pair(6))
                left.addnstr(y, x, ch_name, max_name_len)
                left.attroff(curses.color_pair(6))
                x += max_name_len
                if prog_preview:
                    sep = " │ "
                    left.addstr(y, x, sep)
                    x += len(sep)
                    left.attron(curses.color_pair(4))
                    left.addnstr(y, x, prog_preview, max_prog_len)
                    left.attroff(curses.color_pair(4))

        # Right pane header
        right.attron(curses.color_pair(1))
        right.addnstr(0, 2, " Now Playing ", w - pane_width - 4)
        right.attroff(curses.color_pair(1))

        # Use CurrentProgram from channel call; fall back to EPG scan
        program = jf_sel.get("CurrentProgram") or get_current_program(selected_epg, now)

        info_lines    = [f"Channel: {sel_num}", f"Name:    {sel_ch['GuideName']}", ""]
        pct           = 0
        remaining_sec = 0

        if program:
            title_txt     = program.get("Name", "Unknown")
            episode_title = program.get("EpisodeTitle", "")
            start_dt      = parse_utc(program["StartDate"])
            end_dt        = parse_utc(program["EndDate"])
            local_start   = to_local(start_dt)
            local_end     = to_local(end_dt)
            total_sec     = (end_dt - start_dt).total_seconds()
            elapsed_sec   = (now - start_dt).total_seconds()
            remaining_sec = (end_dt - now).total_seconds()
            pct = min(max(elapsed_sec / total_sec, 0), 1)

            info_lines += [
                "Now Playing:",
                title_txt,
                "",
                f"Ends in: {fmt_countdown(remaining_sec)}",
                f"Start:   {local_start.strftime('%I:%M %p')}",
                f"End:     {local_end.strftime('%I:%M %p')}",
            ]
            if episode_title:
                info_lines += ["", f"Episode: {episode_title}"]

            # Up Next — always show if we have EPG data for this channel
            upcoming_all = get_upcoming_programs(selected_epg, end_dt, count=3)
            if upcoming_all:
                nxt       = upcoming_all[0]
                nxt_local = to_local(parse_utc(nxt["StartDate"]))
                nxt_ep    = nxt.get("EpisodeTitle", "")
                info_lines += ["", "Up Next:"]
                info_lines.append(f"  {trunc(nxt.get('Name', ''), w - pane_width - 6)}")
                if nxt_ep:
                    info_lines.append(f"  {trunc(nxt_ep, w - pane_width - 6)}")
                info_lines.append(f"  Starts: {nxt_local.strftime('%I:%M %p')}")

            # Timeline
            if len(info_lines) + 6 < h - 6:
                prev_prog = get_previous_program(selected_epg, start_dt)
                upcoming1 = get_upcoming_programs(selected_epg, end_dt, count=1)
                info_lines += ["", "━━━━━ Timeline ━━━━━"]
                tl = []
                if prev_prog:
                    prev_end_local = to_local(parse_utc(prev_prog["EndDate"]))
                    tl += [
                        ("  ┌─ Previously:", 17),
                        (f"  │  {trunc(prev_prog.get('Name',''), 25)}", 17),
                        (f"  │  Ended: {prev_end_local.strftime('%I:%M %p')}", 17),
                        ("  │", 17),
                    ]
                tl += [
                    ("  ├─► NOW PLAYING:", 18),
                    (f"  │   {trunc(title_txt, 25)}", 18),
                    (f"  │   Progress: {int(pct*100)}% [{fmt_countdown(remaining_sec)} left]", 18),
                    ("  │", 18),
                ]
                if upcoming1:
                    nxt       = upcoming1[0]
                    nxt_local = to_local(parse_utc(nxt["StartDate"]))
                    tl += [("  └─► Up Next:", 19), (f"     {trunc(nxt.get('Name',''), 25)}", 19)]
                    if nxt.get("EpisodeTitle"):
                        tl.append((f"     Episode: {trunc(nxt['EpisodeTitle'], 20)}", 19))
                    tl.append((f"     Starts: {nxt_local.strftime('%I:%M %p')}", 19))
                info_lines.extend(tl)

            # Coming up later
            upcoming = get_upcoming_programs(selected_epg, end_dt, count=3)
            if len(upcoming) > 1:
                info_lines += ["", "Coming Up Later:"]
                for up in upcoming[1:]:
                    up_local = to_local(parse_utc(up["StartDate"]))
                    ep = up.get("EpisodeTitle", "")
                    line = (
                        f"{up_local.strftime('%I:%M %p')} - {trunc(up.get('Name',''), 15)}: {trunc(ep, 15)}"
                        if ep else
                        f"{up_local.strftime('%I:%M %p')} - {trunc(up.get('Name',''), w - pane_width - 10)}"
                    )
                    info_lines.append(f"  {line}")
        else:
            info_lines += ["Now Playing:", "No EPG data"]

        right.attron(curses.color_pair(6))
        for i, line in enumerate(info_lines):
            if i + 2 >= h - 3:
                break
            if isinstance(line, tuple):
                txt, cp_num = line
                right.attron(curses.color_pair(cp_num) | curses.A_BOLD)
                right.addnstr(i + 2, 2, txt, w - pane_width - 4)
                right.attroff(curses.color_pair(cp_num) | curses.A_BOLD)
            elif program and i == 4:
                right.attron(curses.A_BOLD)
                right.addnstr(i + 2, 2, line, w - pane_width - 4)
                right.attroff(curses.A_BOLD)
            else:
                right.addnstr(i + 2, 2, line, w - pane_width - 4)
        right.attroff(curses.color_pair(6))

        if program:
            bar_y = 5
            right.move(bar_y, 1)
            right.clrtoeol()
            label = "Progress:"
            right.addstr(bar_y, 2, label)
            bar_x = 2 + len(label) + 1
            draw_progress_bar(right, bar_y, bar_x, pct, 22)
            right.addstr(bar_y, bar_x + 24, f"{int(pct*100)}%")

        # Footer
        footer = " ↑↓ Navigate   ENTER Watch   / Search   ESC Clear   q Quit "
        stdscr.attron(curses.color_pair(4))
        stdscr.addnstr(h - 1, 2, footer.ljust(w - 4), w - 4)
        stdscr.attroff(curses.color_pair(4))

        if search_mode or search_query:
            search_text = (
                f"Search: {search_query}_" if search_mode
                else f"Filter: {search_query} ({len(filtered_channels)} channels)"
            )
            stdscr.attron(curses.color_pair(1))
            stdscr.addnstr(h - 2, 2, search_text[:w - 4], w - 4)
            stdscr.attroff(curses.color_pair(1))

        # Input
        key = stdscr.getch()

        if key == ord('q') and not search_mode:
            break
        elif key == ord('/') and not search_mode:
            search_mode  = True
            search_query = ""
            curses.curs_set(1)
        elif key == 27:
            search_mode       = False
            search_query      = ""
            filtered_channels = hdhr_channels[:]
            selected          = 0
            scroll            = 0
            curses.curs_set(0)
        elif search_mode:
            if key in (curses.KEY_BACKSPACE, 127, 8):
                search_query = search_query[:-1]
            elif key in (10, 13):
                search_mode = False
                curses.curs_set(0)
            elif 32 <= key <= 126:
                search_query += chr(key)
            if search_query:
                q = search_query.lower()
                filtered_channels = [
                    ch for ch in hdhr_channels
                    if q in str(ch["GuideNumber"]).lower()
                    or q in ch["GuideName"].lower()
                    or q in (jf_by_number.get(ch["GuideNumber"], {})
                             .get("CurrentProgram") or {}).get("Name", "").lower()
                ]
            else:
                filtered_channels = hdhr_channels[:]
            selected = 0
            scroll   = 0
        elif key == curses.KEY_UP:
            selected = max(0, selected - 1)
        elif key == curses.KEY_DOWN:
            selected = min(len(display_channels) - 1, selected + 1)
        elif key in (10, 13):
            launch_mpv(sel_num)

        stdscr.refresh()


if __name__ == "__main__":
    curses.wrapper(main)